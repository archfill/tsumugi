# Tsumugi 環境変数サンプル
# `cp .env.example .env` でコピーして調整

# ---- Postgres ----
TSUMUGI_PG_PASSWORD=tsumugi_dev
DATABASE_URL=postgresql://tsumugi:tsumugi_dev@localhost:5433/tsumugi

# ---- MCP server ----
PORT=8000
NODE_ENV=development

# ---- LLM (cold path, dreaming で利用) ----
# 設定例: Z.ai / DeepSeek / Anthropic 等
LLM_LOW_PROVIDER=deepseek
LLM_LOW_API_KEY=
LLM_LOW_MODEL=deepseek-chat

LLM_MID_PROVIDER=anthropic
LLM_MID_API_KEY=
LLM_MID_MODEL=claude-haiku-4-5

# ---- Embedding cache ----
HF_CACHE=./.cache/huggingface
