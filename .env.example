# Tsumugi 環境変数サンプル
# `cp .env.example .env` でコピーして調整。
# 本番運用では 1Password Environment 経由でマウント推奨。

# ---- Postgres ----
TSUMUGI_PG_PASSWORD=tsumugi_dev
DATABASE_URL=postgresql://tsumugi:tsumugi_dev@localhost:5433/tsumugi

# ---- MCP server ----
PORT=8000
NODE_ENV=development

# ---- LLM (cold path: dreaming で利用) ----
#
# tsumugi は LLM provider 非依存。tier 別 (LOW/MID) に provider を選べる。
#
# 対応 provider:
#   - anthropic      : Claude (claude-haiku-4-5, claude-sonnet-4-6 等)
#   - openai-compat  : OpenAI 互換 API (Z.ai / DeepSeek / OpenRouter / Ollama / OpenAI 本家)
#
# Z.ai GLM Coding Plan を使う場合 (subscription で API 料金が定額化):
#   LLM_*_PROVIDER=openai-compat
#   LLM_*_BASE_URL=https://api.z.ai/api/paas/v4
#   LLM_LOW_MODEL=glm-4.5-air   (軽量・高速)
#   LLM_MID_MODEL=glm-4.6        (最新、reasoning 強い、AUDN/矛盾検出向き)

# --- LOW tier (summarize / narrative / 軽い分類) ---
LLM_LOW_PROVIDER=openai-compat
LLM_LOW_API_KEY=
LLM_LOW_MODEL=glm-4.5-air
LLM_LOW_BASE_URL=https://api.z.ai/api/paas/v4

# --- MID tier (AUDN 判定 / decision 矛盾検出 等の意味判定) ---
LLM_MID_PROVIDER=openai-compat
LLM_MID_API_KEY=
LLM_MID_MODEL=glm-4.6
LLM_MID_BASE_URL=https://api.z.ai/api/paas/v4

# ---- LLM resilience (任意) ----
# Layer 1: 各 provider client が exponential backoff retry を行う
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=30000

# Layer 3: fallback provider (primary が retry 後も失敗したら 1 回だけ試行)
# API_KEY を未設定にすると fallback 無効。Anthropic Haiku に逃すのが定番。
# LLM_LOW_FALLBACK_PROVIDER=anthropic
# LLM_LOW_FALLBACK_API_KEY=
# LLM_LOW_FALLBACK_MODEL=claude-haiku-4-5
#
# LLM_MID_FALLBACK_PROVIDER=anthropic
# LLM_MID_FALLBACK_API_KEY=
# LLM_MID_FALLBACK_MODEL=claude-sonnet-4-6

# ---- Logging ----
# pino logger level: trace | debug | info | warn | error | fatal
# (default: NODE_ENV=production なら info、それ以外なら debug)
# LOG_LEVEL=info

# ---- Dreaming scheduler (cron 自動実行) ----
# http モードでのみ起動。空文字列 ("") で当該 job 無効化。
# scheduler 全停止は DREAMING_SCHEDULER_ENABLED=false
# DREAMING_SCHEDULER_ENABLED=true
# DREAMING_SCHEDULE_PROMOTE_CAPTURES="0,30 * * * *"      # 30 分ごと capture window 昇格
# DREAMING_SCHEDULE_PROMOTE_OBSERVATIONS="5,35 * * * *"  # その 5 分後に fact 昇格
# DREAMING_SCHEDULE_SWEEP_CAPTURES="30 2 * * *"           # 毎日 02:30 Layer 1 TTL sweep
# DREAMING_SCHEDULE_SYNTHESIZE="0 */6 * * *"     # 6 時間ごと synthesize
# DREAMING_SCHEDULE_TIME_UPDATE="0 3 * * *"      # 毎日 03:00 time-update
# DREAMING_SCHEDULE_DECISION_CONTRADICTION="0 4 * * 0"  # 毎週日曜 04:00 decision-contradiction

# ---- Embedding cache ----
HF_CACHE=./.cache/huggingface
