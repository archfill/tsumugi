# Tsumugi 環境変数サンプル
# `cp .env.example .env` でコピーして調整。
# 本番運用では 1Password Environment 経由でマウント推奨。

# ---- Postgres ----
TSUMUGI_PG_PASSWORD=tsumugi_dev
DATABASE_URL=postgresql://tsumugi:tsumugi_dev@localhost:5433/tsumugi

# ---- MCP server ----
PORT=8000
NODE_ENV=development

# ---- LLM (cold path: dreaming で利用) ----
#
# tsumugi は LLM provider 非依存。tier 別 (LOW/MID) に provider を選べる。
#
# 対応 provider:
#   - anthropic      : Claude (claude-haiku-4-5, claude-sonnet-4-6 等)
#   - openai-compat  : OpenAI 互換 API (Z.ai / DeepSeek / OpenRouter / Ollama / OpenAI 本家)
#
# Z.ai GLM Coding Plan を使う場合 (subscription で API 料金が定額化):
#   LLM_*_PROVIDER=openai-compat
#   LLM_*_BASE_URL=https://api.z.ai/api/paas/v4
#   LLM_LOW_MODEL=glm-4.5-air   (軽量・高速)
#   LLM_MID_MODEL=glm-4.6        (最新、reasoning 強い、AUDN/矛盾検出向き)

# --- LOW tier (summarize / narrative / 軽い分類) ---
LLM_LOW_PROVIDER=openai-compat
LLM_LOW_API_KEY=
LLM_LOW_MODEL=glm-4.5-air
LLM_LOW_BASE_URL=https://api.z.ai/api/paas/v4

# --- MID tier (AUDN 判定 / decision 矛盾検出 等の意味判定) ---
LLM_MID_PROVIDER=openai-compat
LLM_MID_API_KEY=
LLM_MID_MODEL=glm-4.6
LLM_MID_BASE_URL=https://api.z.ai/api/paas/v4

# ---- Embedding cache ----
HF_CACHE=./.cache/huggingface
