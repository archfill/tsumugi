# Tsumugi 環境変数サンプル
# `cp .env.example .env` でコピーして調整

# ---- Postgres ----
TSUMUGI_PG_PASSWORD=tsumugi_dev
DATABASE_URL=postgresql://tsumugi:tsumugi_dev@localhost:5433/tsumugi

# ---- MCP server ----
PORT=8000
NODE_ENV=development

# ---- LLM (cold path: dreaming で利用) ----
# Anthropic Claude を tier 別に使い分け
# LOW : 軽い要約・narrative 生成 (Haiku)
# MID : 意味判定 (AUDN / 矛盾検出) (Sonnet)
LLM_LOW_API_KEY=
LLM_LOW_MODEL=claude-haiku-4-5

LLM_MID_API_KEY=
LLM_MID_MODEL=claude-sonnet-4-6

# ---- Embedding cache ----
HF_CACHE=./.cache/huggingface
