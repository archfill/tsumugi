{
  "name": "@tsumugi/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts --http",
    "dev:http": "tsx watch src/index.ts --http",
    "dev:stdio": "tsx watch src/index.ts --stdio",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "start:stdio": "node dist/index.js --stdio",
    "lint": "echo 'lint: not configured yet'",
    "typecheck": "tsc -b",
    "test": "echo 'no tests yet'",
    "check": "pnpm typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "search:smoke": "tsx src/core/search/smoke.ts",
    "mcp:smoke": "tsx src/interfaces/mcp/smoke.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tsumugi/shared": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
